# ────────────────────────────────────────────────────
#  JAPAN TEA ISE-CHA — Square 環境変数設定
#  このファイルを .env にコピーして値を設定してください
#  cp .env.example .env
# ────────────────────────────────────────────────────

# Square Developer Console から取得
# https://developer.squareup.com/apps

# --- Sandbox (テスト環境) ---
SQUARE_ACCESS_TOKEN=EAAAl-sandbox-xxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=Lxxxxxxxxxxxxxxxxx
SQUARE_APP_ID=sandbox-sq0idb-xxxxxxxxxxxxxxxxxxxxxxxx
SQUARE_ENV=sandbox

# --- Production (本番環境) ---
# SQUARE_ACCESS_TOKEN=EAAAl-xxxxxxxxxxxxxxxxxxxxxxxx
# SQUARE_LOCATION_ID=Lxxxxxxxxxxxxxxxxx
# SQUARE_APP_ID=sq0idp-xxxxxxxxxxxxxxxxxxxxxxxx
# SQUARE_ENV=production

# サーバー設定
PORT=3000

# CORS (フロントエンドのURLを設定)
ALLOWED_ORIGIN=http://localhost:3000
